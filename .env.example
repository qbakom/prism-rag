# === PRISM Configuration ===

# API
APP_HOST=0.0.0.0
APP_PORT=8000

# Qdrant (baza wektorowa)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LLM Backend: "gemini" (cloud) lub "ollama" (local)
LLM_BACKEND=gemini

# Gemini API (gdy LLM_BACKEND=gemini)
# Pobierz klucz: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Ollama (gdy LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model
EMBEDDING_MODEL=BAAI/bge-m3
